{% extends 'base.html.twig' %}

{% block title %}Intervention{% endblock %}

{% block body %}
    <h1>Intervention</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ action.id }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ action.date ? action.date|date('Y-m-d H:i') : '' }}</td>
            </tr>
            <tr>
                <th>Plante</th>
                <td>{{ action.vegetable ? action.vegetable.name : '' }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ action.typeAction }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ action.title }}</td>
            </tr>
            <tr>
                <th>Commentaire</th>
                <td>{{ action.comment }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_action_index') }}">Retour à la liste</a>

    <a href="{{ path('app_action_edit', {'id': action.id}) }}">Modifier</a>

    {{ include('action/_delete_form.html.twig') }}
{% endblock %}
