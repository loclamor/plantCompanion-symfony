{% extends 'base.html.twig' %}

{% block title %}Interventions{% endblock %}

{% block body %}
    <h1>Interventions</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Date</th>
                <th>Plante</th>
                <th>Type</th>
                <th>Titre</th>
                <th>Commentaire</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for action in actions %}
            <tr>
                <td>{{ action.id }}</td>
                <td>{{ action.date ? action.date|date('Y-m-d H:i') : '' }}</td>
                <td>{{ action.vegetable ? action.vegetable.name : '' }}</td>
                <td>{{ action.typeAction }}</td>
                <td>{{ action.title }}</td>
                <td>{{ action.comment }}</td>
                <td>
                    <a href="{{ path('app_action_show', {'id': action.id}) }}">Voir</a>
                    <a href="{{ path('app_action_edit', {'id': action.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">Aucun enregistrement</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_action_new') }}">Créer</a>
{% endblock %}
