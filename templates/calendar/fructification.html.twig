{% extends 'base.html.twig' %}

{% block title %}Calendrier de fructification{% endblock %}

{% set mois = {1:'Jan', 2:'Fév', 3:'Mar', 4:'Avr', 5:'Mai', 6:'Juin', 7:'Juil', 8:'Aoû', 9:'Sep', 10:'Oct', 11:'Nov', 12:'Déc'} %}

{% block body %}
    <h1>Calendrier de fructification</h1>

    {% if current_group %}
        <p class="text-muted">Groupe courant : <strong>{{ current_group.name }}</strong></p>
    {% endif %}

    <p>
        <span class="badge bg-success">Floraison</span>
        <span class="badge bg-warning text-dark">Récolte</span>
    </p>

    <table class="table table-bordered text-center align-middle">
        <thead>
            <tr>
                <th>Plante</th>
                {% for m in months %}
                    <th>{{ mois[m] }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
        {% for row in rows %}
            <tr>
                <td class="text-start">
                    <a href="{{ path('app_vegetable_show', {'id': row.vegetable.id}) }}">{{ row.vegetable.name }}</a>
                </td>
                {% for m in months %}
                    {% set isFleur = m in row.fleur %}
                    {% set isFructi = m in row.fructi %}
                    <td class="{{ isFleur and isFructi ? 'bg-info' : (isFleur ? 'bg-success' : (isFructi ? 'bg-warning' : '')) }}">&nbsp;</td>
                {% endfor %}
            </tr>
        {% else %}
            <tr>
                <td colspan="13">Aucune plante</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
