{% extends 'base.html.twig' %}

{% block title %}Groupe{% endblock %}

{% block body %}
    <h1>Groupe</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ group.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ group.name }}</td>
            </tr>
            <tr>
                <th>Parent</th>
                <td>{{ group.parent ? group.parent.name : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_group_index') }}">Retour à la liste</a>

    <a href="{{ path('app_group_edit', {'id': group.id}) }}">Modifier</a>

    {{ include('group/_delete_form.html.twig') }}
{% endblock %}
