{% extends 'base.html.twig' %}

{% block title %}Types{% endblock %}

{% block body %}
    <h1>Types</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Parent</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for type in types %}
            <tr>
                <td>{{ type.id }}</td>
                <td>{{ type.name }}</td>
                <td>{{ type.parent ? type.parent.name : '' }}</td>
                <td>
                    <a href="{{ path('app_type_show', {'id': type.id}) }}">Voir</a>
                    <a href="{{ path('app_type_edit', {'id': type.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucun enregistrement</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_type_new') }}">Créer</a>
{% endblock %}
