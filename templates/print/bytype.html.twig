{% extends 'base.html.twig' %}

{% block title %}Impression par type{% endblock %}

{% block stylesheets %}
    <style>
        .plant-card {
            width: 9.5cm;
            min-height: 6cm;
            border: 1px solid #ccc;
            padding: .5cm;
            margin: .3cm;
            display: inline-block;
            vertical-align: top;
        }
        @media print {
            .no-print { display: none; }
            .plant-card { page-break-inside: avoid; }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="no-print">
        <h1>Impression par type</h1>
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <select name="type" class="form-select">
                    <option value="">Choisir un type…</option>
                    {% for type in types %}
                        <option value="{{ type.id }}" {{ selectedType and selectedType.id == type.id ? 'selected' : '' }}>{{ type.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary">Afficher</button>
                {% if selectedType %}
                    <button type="button" class="btn btn-outline-secondary" onclick="window.print()">Imprimer</button>
                {% endif %}
            </div>
        </form>
    </div>

    {% if selectedType %}
        <div>
            {% for vegetable in vegetables %}
                <div class="plant-card">
                    <strong>{{ vegetable.name }}</strong><br>
                    {% if vegetable.nomLatin %}<em>{{ vegetable.nomLatin }}</em><br>{% endif %}
                    Rusticité : {{ vegetable.rusticite }}<br>
                    {% if vegetable.defaultPhoto and vegetable.defaultPhoto.relativePath %}
                        <img src="{{ path('liip_imagine_filter', {filter: 'plant_thumb', path: vegetable.defaultPhoto.relativePath}) }}" alt="photo">
                    {% endif %}
                </div>
            {% else %}
                <p>Aucune plante pour ce type.</p>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
