{% extends 'base.html.twig' %}

{% block title %}Vegetable{% endblock %}

{% block body %}
    <h1>Vegetable</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ vegetable.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ vegetable.name }}</td>
            </tr>
            <tr>
                <th>CreationDate</th>
                <td>{{ vegetable.creationDate ? vegetable.creationDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>AddDate</th>
                <td>{{ vegetable.addDate ? vegetable.addDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>TypeOrigine</th>
                <td>{{ vegetable.typeOrigine }}</td>
            </tr>
            <tr>
                <th>NomLatin</th>
                <td>{{ vegetable.nomLatin }}</td>
            </tr>
            <tr>
                <th>Rusticite</th>
                <td>{{ vegetable.rusticite }}</td>
            </tr>
            <tr>
                <th>MoisFructiDebut</th>
                <td>{{ vegetable.moisFructiDebut }}</td>
            </tr>
            <tr>
                <th>MoisFructiFin</th>
                <td>{{ vegetable.moisFructiFin }}</td>
            </tr>
            <tr>
                <th>MoisFleurDebut</th>
                <td>{{ vegetable.moisFleurDebut }}</td>
            </tr>
            <tr>
                <th>MoisFleurFin</th>
                <td>{{ vegetable.moisFleurFin }}</td>
            </tr>
            <tr>
                <th>PFleur</th>
                <td>{{ vegetable.pFleur }}</td>
            </tr>
            <tr>
                <th>PFructi</th>
                <td>{{ vegetable.pFructi }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_vegetable_index') }}">back to list</a>

    <a href="{{ path('app_vegetable_edit', {'id': vegetable.id}) }}">edit</a>

    {{ include('vegetable/_delete_form.html.twig') }}

    <h2 class="mt-4">Photos</h2>
    <p>
        <a class="btn btn-sm btn-primary" href="{{ path('app_photo_new', {'vegetable': vegetable.id}) }}">Ajouter une photo</a>
        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_photo_upload_multiple') }}">Ajouter plusieurs photos</a>
    </p>
    <div class="row">
        {% for photo in photos %}
            <div class="col-md-3 mb-3">
                <div class="card {{ vegetable.defaultPhoto and vegetable.defaultPhoto.id == photo.id ? 'border-success' : '' }}">
                    {% if photo.relativePath %}
                        <img src="{{ path('liip_imagine_filter', {filter: 'plant_thumb', path: photo.relativePath}) }}" class="card-img-top" alt="photo">
                    {% endif %}
                    <div class="card-body p-2">
                        {% if vegetable.defaultPhoto and vegetable.defaultPhoto.id == photo.id %}
                            <span class="badge bg-success">Photo par défaut</span>
                        {% else %}
                            <form method="post" action="{{ path('app_photo_set_default', {'id': photo.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('default' ~ photo.id) }}">
                                <button class="btn btn-sm btn-outline-secondary">Définir par défaut</button>
                            </form>
                        {% endif %}
                        <form method="post" action="{{ path('app_photo_delete', {'id': photo.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette photo ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ photo.id) }}">
                            <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        {% else %}
            <p>Aucune photo.</p>
        {% endfor %}
    </div>

    <h2 class="mt-4">Interventions</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Titre</th>
                <th>Commentaire</th>
            </tr>
        </thead>
        <tbody>
        {% for action in actions %}
            <tr>
                <td>{{ action.date ? action.date|date('Y-m-d H:i') : '' }}</td>
                <td>{{ action.typeAction }}</td>
                <td><a href="{{ path('app_action_show', {'id': action.id}) }}">{{ action.title }}</a></td>
                <td>{{ action.comment }}</td>
            </tr>
        {% else %}
            <tr><td colspan="4">Aucune intervention</td></tr>
        {% endfor %}
        </tbody>
    </table>

    <h2 class="mt-4">Historique des modifications</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Champ</th>
                <th>Ancienne valeur</th>
                <th>Nouvelle valeur</th>
            </tr>
        </thead>
        <tbody>
        {% for history in histories %}
            <tr>
                <td>{{ history.date ? history.date|date('Y-m-d H:i') : '' }}</td>
                <td>{{ history.key }}</td>
                <td>{{ history.oldValue }}</td>
                <td>{{ history.newValue }}</td>
            </tr>
        {% else %}
            <tr><td colspan="4">Aucune modification enregistrée</td></tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
